generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYER
  CANDIDATE
}

enum QuestionType {
  CHECKBOX
  RADIO
  TEXT
}

enum SubmissionStatus {
  ASSIGNED
  PENDING
  IN_PROGRESS
  COMPLETED
}

model User {
  id        String   @id @default(cuid())
  name      String?  @default("")
  email     String   @unique
  password  String
  role      Role     @default(CANDIDATE)
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  exams     Exam[]   @relation("EmployerExams")
  submissions Submission[]
}

model Exam {
  id              String   @id @default(cuid())
  title           String
  totalCandidates Int      @default(0)
  totalSlots      Int      @default(0)
  questionSets    Int      @default(0)
  questionType    String?
  startTime       DateTime
  endTime         DateTime
  duration        Int // in minutes
  negativeMarking Float    @default(0.0)
  image           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employerId      String
  employer        User     @relation("EmployerExams", fields: [employerId], references: [id])
  
  questions       Question[]
  submissions     Submission[]
}

model Question {
  id        String       @id @default(cuid())
  title     String       @db.Text
  type      QuestionType @default(RADIO)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  examId    String
  exam      Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  
  options   Option[]
}

model Option {
  id         String   @id @default(cuid())
  text       String
  isCorrect  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Submission {
  id             String           @id @default(cuid())
  status         SubmissionStatus @default(PENDING)
  score          Float            @default(0.0)
  tabSwitches    Int              @default(0)
  fullscreenExits Int             @default(0)
  startedAt      DateTime?
  submittedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  userId         String
  user           User   @relation(fields: [userId], references: [id])
  
  examId         String
  exam           Exam   @relation(fields: [examId], references: [id])

  @@unique([userId, examId])
}
